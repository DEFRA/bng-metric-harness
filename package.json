{
  "name": "bng-metric-harness",
  "version": "0.0.0",
  "private": true,
  "description": "Meta-repo that orchestrates bng-metric-frontend and bng-metric-backend",
  "type": "module",
  "imports": {
    "#gpkg-io": "./packages/bng-lib/src/gpkg-io/index.mjs",
    "#bng-lib": "./packages/bng-lib/index.mjs"
  },
  "engines": {
    "node": ">=24.14.1"
  },
  "scripts": {
    "bootstrap": "node scripts/bootstrap.mjs",
    "install:all": "node scripts/install.mjs all",
    "install:fe": "node scripts/install.mjs fe",
    "install:be": "node scripts/install.mjs be",
    "dev": "node scripts/dev.mjs all",
    "dev:fe": "node scripts/dev.mjs fe",
    "dev:be": "node scripts/dev.mjs be",
    "status": "node scripts/status.mjs",
    "pull": "node scripts/pull.mjs",
    "branch": "node scripts/branch.mjs",
    "fe": "node scripts/proxy.mjs fe",
    "be": "node scripts/proxy.mjs be",
    "lint": "node scripts/lint.mjs",
    "test:scripts": "vitest run tests/scripts/gpkg",
    "test:scripts:watch": "vitest tests/scripts/gpkg",
    "generate:gpkg": "node scripts/gen-gpkg.mjs",
    "generate:gpkg:docker": "docker compose -f compose.gen-gpkg.yml run --rm --build gen-gpkg",
    "likec4": "npx likec4 start likec4",
    "likec4:export": "docker run --rm -v \"$PWD:/data\" -w /data likec4/likec4 export png -o ./arch-diagrams likec4",
    "docs:aggregate": "node scripts/build-docs.mjs",
    "docs:likec4": "npx likec4 build --base ./ --use-hash-history -o site_src/docs/architecture/app likec4",
    "docs:build": "npm run docs:aggregate && npm run docs:likec4 && mkdocs build",
    "docs:serve": "npm run docs:aggregate && npm run docs:likec4 && mkdocs serve",
    "setup:husky": "node -e \"try { (await import('husky')).default() } catch (e) { if (e.code !== 'ERR_MODULE_NOT_FOUND') throw e }\" --input-type module",
    "install:gitleaks": "node scripts/install-gitleaks.mjs",
    "postinstall": "node scripts/postinstall.mjs",
    "git:pre-commit-hook": "node scripts/run-gitleaks.mjs"
  },
  "dependencies": {
    "concurrently": "^9.1.0"
  },
  "devDependencies": {
    "better-sqlite3": "^12.9.0",
    "husky": "9.1.7",
    "likec4": "^1.56.0",
    "remark-parse": "^11.0.0",
    "remark-stringify": "^11.0.0",
    "unified": "^11.0.5",
    "unist-util-visit": "^5.0.0",
    "vitest": "^3.0.0",
    "xlsx": "^0.18.5"
  }
}
